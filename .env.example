# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=stockbot
MYSQL_PASSWORD=stockbot_password
MYSQL_DATABASE=stockbot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# News API (https://newsapi.org - free tier works)
NEWS_API_KEY=your_newsapi_key_here

# Bot settings
MAX_CONVERSATION_TURNS=20      # turns kept in Redis per user
CLAUDE_MODEL=claude-sonnet-4-6
